{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"includes": [
			"**",
			"!!**/dist",
			"!!**/coverage",
			"!!**/.next",
			"!!**/.turbo",
			"!!**/drizzle",
			"!!**/*.sqlite*"
		],
		"ignoreUnknown": true,
		"maxSize": 1048576
	},
	"formatter": {
		"enabled": true,
		"includes": [
			"src/**",
			"styles/**",
			"build.ts",
			"drizzle.config.ts",
			".zed/**",
			"biome.json",
			"components.json",
			"package.json",
			"tsconfig.json"
		],
		"formatWithErrors": false,
		"indentStyle": "tab",
		"lineWidth": 100,
		"lineEnding": "lf",
		"attributePosition": "auto",
		"bracketSpacing": true
	},
	"linter": {
		"enabled": true,
		"includes": [
			"src/**",
			"styles/**",
			"build.ts",
			"drizzle.config.ts",
			".zed/**",
			"components.json"
		],
		"domains": {
			"project": "recommended",
			"react": "recommended"
		},
		"rules": {
			"recommended": true,
			"correctness": {
				"noUndeclaredDependencies": "error",
				"noUnusedImports": "error"
			},
			"style": {
				"useImportType": "error"
			}
		}
	},
	"javascript": {
		"jsxRuntime": "transparent",
		"formatter": {
			"quoteStyle": "double",
			"jsxQuoteStyle": "double",
			"quoteProperties": "asNeeded",
			"trailingCommas": "all",
			"semicolons": "always",
			"arrowParentheses": "always",
			"bracketSameLine": false,
			"operatorLinebreak": "after"
		}
	},
	"json": {
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": true
		},
		"formatter": {
			"trailingCommas": "none",
			"lineWidth": 100
		}
	},
	"assist": {
		"enabled": true,
		"includes": ["src/**", "styles/**", "build.ts", "drizzle.config.ts", ".zed/**"],
		"actions": {
			"recommended": true,
			"source": {
				"organizeImports": {
					"options": {
						"groups": [
							[":BUN:", ":NODE:"],
							":BLANK_LINE:",
							["react", "react/**", "react-*", "react-*/**"],
							":BLANK_LINE:",
							[":PACKAGE:", "!@/**"],
							":BLANK_LINE:",
							"@/**",
							":BLANK_LINE:",
							":PATH:"
						]
					}
				}
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": true,
			"lineWidth": 100,
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"includes": ["**/*.{test,spec}.{js,jsx,ts,tsx}", "src/**/test/**", "src/**/tests/**"],
			"linter": {
				"domains": {
					"test": "recommended"
				}
			}
		}
	]
}
