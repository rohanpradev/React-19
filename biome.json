{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!dist", "!drizzle", "!*.sqlite", "!*.sqlite-shm", "!*.sqlite-wal"],
		"ignoreUnknown": true
	},
	"formatter": {
		"enabled": true,
		"includes": [
			"src/**",
			"styles/**",
			"build.ts",
			"drizzle.config.ts",
			"biome.json",
			"package.json",
			"tsconfig.json"
		],
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"includes": ["src/**", "styles/**", "build.ts", "drizzle.config.ts"],
		"domains": {
			"project": "recommended",
			"react": "recommended"
		},
		"rules": {
			"recommended": true,
			"style": {
				"useImportType": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"includes": ["src/**", "styles/**", "build.ts", "drizzle.config.ts"],
		"actions": {
			"recommended": true,
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
